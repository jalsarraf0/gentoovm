#!/usr/bin/env python3
"""GentooVM Kernel Manager - GTK GUI"""

import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, GLib, Pango
import subprocess
import os
import sys
import threading
import re
import urllib.request
import json


class KernelManagerWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title="GentooVM Kernel Manager")
        self.set_default_size(700, 500)
        self.set_border_width(10)
        self.set_position(Gtk.WindowPosition.CENTER)

        # Check root
        if os.geteuid() != 0:
            self._show_root_dialog()
            return

        self._build_ui()
        self._refresh_all()

    def _show_root_dialog(self):
        dialog = Gtk.MessageDialog(
            parent=self,
            modal=True,
            message_type=Gtk.MessageType.ERROR,
            buttons=Gtk.ButtonsType.OK,
            text="Root privileges required",
        )
        dialog.format_secondary_text(
            "Run from terminal:\n  sudo gentoovm-kernel-manager-gui\n\n"
            "Or use the CLI version:\n  sudo gentoovm-kernel-manager"
        )
        dialog.run()
        dialog.destroy()
        sys.exit(1)

    def _build_ui(self):
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        self.add(vbox)

        # Header
        header = Gtk.Label()
        header.set_markup('<span size="x-large" weight="bold">GentooVM Kernel Manager</span>')
        vbox.pack_start(header, False, False, 4)

        # Current kernel info
        self.current_label = Gtk.Label()
        self.current_label.set_halign(Gtk.Align.START)
        vbox.pack_start(self.current_label, False, False, 0)

        # Notebook (tabs)
        notebook = Gtk.Notebook()
        vbox.pack_start(notebook, True, True, 0)

        # --- Tab 1: Installed Kernels ---
        installed_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        installed_box.set_border_width(8)

        scroll1 = Gtk.ScrolledWindow()
        scroll1.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        self.installed_store = Gtk.ListStore(str, str, str)  # version, size, status
        self.installed_tree = Gtk.TreeView(model=self.installed_store)
        for i, title in enumerate(["Version", "Size", "Status"]):
            col = Gtk.TreeViewColumn(title, Gtk.CellRendererText(), text=i)
            col.set_expand(i == 0)
            self.installed_tree.append_column(col)
        scroll1.add(self.installed_tree)
        installed_box.pack_start(scroll1, True, True, 0)

        btn_box1 = Gtk.Box(spacing=6)
        btn_remove = Gtk.Button(label="Remove Selected")
        btn_remove.connect("clicked", self._on_remove)
        btn_box1.pack_end(btn_remove, False, False, 0)
        btn_refresh = Gtk.Button(label="Refresh")
        btn_refresh.connect("clicked", lambda w: self._refresh_all())
        btn_box1.pack_end(btn_refresh, False, False, 0)
        installed_box.pack_start(btn_box1, False, False, 0)

        notebook.append_page(installed_box, Gtk.Label(label="Installed"))

        # --- Tab 2: Available Kernels ---
        avail_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        avail_box.set_border_width(8)

        scroll2 = Gtk.ScrolledWindow()
        scroll2.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        self.avail_store = Gtk.ListStore(str, str)  # version, status
        self.avail_tree = Gtk.TreeView(model=self.avail_store)
        for i, title in enumerate(["Version", "Status"]):
            col = Gtk.TreeViewColumn(title, Gtk.CellRendererText(), text=i)
            col.set_expand(i == 0)
            self.avail_tree.append_column(col)
        scroll2.add(self.avail_tree)
        avail_box.pack_start(scroll2, True, True, 0)

        btn_box2 = Gtk.Box(spacing=6)
        btn_install = Gtk.Button(label="Install Selected")
        btn_install.connect("clicked", self._on_install)
        btn_box2.pack_end(btn_install, False, False, 0)
        btn_sync = Gtk.Button(label="Sync Portage")
        btn_sync.connect("clicked", self._on_sync)
        btn_box2.pack_end(btn_sync, False, False, 0)
        avail_box.pack_start(btn_box2, False, False, 0)

        notebook.append_page(avail_box, Gtk.Label(label="Available"))

        # --- Tab 3: kernel.org ---
        web_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        web_box.set_border_width(8)

        self.kernelorg_text = Gtk.TextView()
        self.kernelorg_text.set_editable(False)
        self.kernelorg_text.set_wrap_mode(Gtk.WrapMode.WORD)
        self.kernelorg_text.modify_font(Pango.FontDescription("monospace 10"))
        scroll3 = Gtk.ScrolledWindow()
        scroll3.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        scroll3.add(self.kernelorg_text)
        web_box.pack_start(scroll3, True, True, 0)

        btn_box3 = Gtk.Box(spacing=6)
        btn_check = Gtk.Button(label="Check kernel.org")
        btn_check.connect("clicked", self._on_check_kernelorg)
        btn_box3.pack_end(btn_check, False, False, 0)
        web_box.pack_start(btn_box3, False, False, 0)

        notebook.append_page(web_box, Gtk.Label(label="kernel.org"))

        # --- Status bar ---
        self.statusbar = Gtk.Label()
        self.statusbar.set_halign(Gtk.Align.START)
        vbox.pack_start(self.statusbar, False, False, 0)

        # --- Progress ---
        self.progress = Gtk.ProgressBar()
        self.progress.set_no_show_all(True)
        vbox.pack_start(self.progress, False, False, 0)

    def _set_status(self, msg):
        GLib.idle_add(self.statusbar.set_text, msg)

    def _run_cmd(self, cmd):
        try:
            result = subprocess.run(
                cmd, shell=True, capture_output=True, text=True, timeout=300
            )
            return result.stdout + result.stderr
        except subprocess.TimeoutExpired:
            return "Command timed out"
        except Exception as e:
            return str(e)

    def _refresh_all(self):
        # Current kernel
        current = os.uname().release
        self.current_label.set_markup(
            f'<b>Running kernel:</b> {current}    '
            f'<b>Arch:</b> {os.uname().machine}    '
            f'<b>Default:</b> 7.0 (mainline)  <b>Recommended:</b> 6.19.x (stable)'
        )

        # Installed kernels
        self.installed_store.clear()
        current_short = current
        for f in sorted(os.listdir("/boot")):
            if f.startswith("kernel-"):
                ver = f.replace("kernel-", "")
                path = os.path.join("/boot", f)
                size = f"{os.path.getsize(path) / 1048576:.1f} MB"
                status = "running" if ver == current_short else ""
                self.installed_store.append([ver, size, status])

        # Available kernels
        self.avail_store.clear()
        ebuild_dir = "/var/db/repos/gentoo/sys-kernel/gentoo-kernel-bin/"
        if os.path.isdir(ebuild_dir):
            versions = []
            for f in os.listdir(ebuild_dir):
                if f.endswith(".ebuild"):
                    ver = f.replace("gentoo-kernel-bin-", "").replace(".ebuild", "")
                    versions.append(ver)
            for ver in sorted(versions, key=lambda v: [int(x) if x.isdigit() else x for x in re.split(r'(\d+)', v)]):
                status = ""
                if os.path.exists(f"/boot/kernel-{ver}-gentoo-dist"):
                    status = "installed"
                if f"{ver}-gentoo-dist" == current_short:
                    status = "running"
                self.avail_store.append([ver, status])

        self._set_status("Ready")

    def _on_install(self, widget):
        sel = self.avail_tree.get_selection()
        model, it = sel.get_selected()
        if it is None:
            self._msg("Select a kernel version to install.")
            return

        ver = model[it][0]
        dialog = Gtk.MessageDialog(
            parent=self, modal=True,
            message_type=Gtk.MessageType.QUESTION,
            buttons=Gtk.ButtonsType.YES_NO,
            text=f"Install kernel {ver}?",
        )
        dialog.format_secondary_text(
            "This will download and install the kernel.\n"
            "GRUB will be updated automatically.\n"
            "Select the kernel at boot from the GRUB menu."
        )
        resp = dialog.run()
        dialog.destroy()
        if resp != Gtk.ResponseType.YES:
            return

        self.progress.show()
        self.progress.pulse()
        self._set_status(f"Installing kernel {ver}...")

        def do_install():
            # Ensure keywords
            os.makedirs("/etc/portage/package.accept_keywords", exist_ok=True)
            kw_file = "/etc/portage/package.accept_keywords/kernel"
            needs_write = True
            if os.path.exists(kw_file):
                with open(kw_file) as f:
                    if "gentoo-kernel-bin" in f.read():
                        needs_write = False
            if needs_write:
                with open(kw_file, "a") as f:
                    f.write("sys-kernel/gentoo-kernel-bin ~amd64\n")
                    f.write("virtual/dist-kernel ~amd64\n")

            out = self._run_cmd(
                f"emerge --ask=n --getbinpkg =sys-kernel/gentoo-kernel-bin-{ver}"
            )

            # Create symlinks
            kfile = f"/boot/kernel-{ver}-gentoo-dist"
            ifile = f"/boot/initramfs-{ver}-gentoo-dist.img"
            if os.path.exists(kfile):
                os.system(f"ln -sf {os.path.basename(kfile)} /boot/vmlinuz")
            if os.path.exists(ifile):
                os.system(f"ln -sf {os.path.basename(ifile)} /boot/initramfs.img")

            # Update GRUB
            out2 = self._run_cmd("grub-mkconfig -o /boot/grub/grub.cfg")

            GLib.idle_add(self._install_done, ver, out + "\n" + out2)

        threading.Thread(target=do_install, daemon=True).start()
        GLib.timeout_add(200, self._pulse_progress)

    def _pulse_progress(self):
        if self.progress.get_visible():
            self.progress.pulse()
            return True
        return False

    def _install_done(self, ver, output):
        self.progress.hide()
        self._refresh_all()
        if os.path.exists(f"/boot/kernel-{ver}-gentoo-dist"):
            self._set_status(f"Kernel {ver} installed. Reboot and select from GRUB menu.")
            self._msg(f"Kernel {ver} installed successfully!\n\n"
                      f"Reboot to use it. Select it from the GRUB boot menu.")
        else:
            self._set_status(f"Installation of {ver} may have failed.")
            self._msg(f"Installation output:\n\n{output[-500:]}", error=True)

    def _on_remove(self, widget):
        sel = self.installed_tree.get_selection()
        model, it = sel.get_selected()
        if it is None:
            self._msg("Select a kernel to remove.")
            return

        ver = model[it][0]
        current = os.uname().release
        if ver == current:
            self._msg("Cannot remove the currently running kernel.", error=True)
            return

        dialog = Gtk.MessageDialog(
            parent=self, modal=True,
            message_type=Gtk.MessageType.WARNING,
            buttons=Gtk.ButtonsType.YES_NO,
            text=f"Remove kernel {ver}?",
        )
        resp = dialog.run()
        dialog.destroy()
        if resp != Gtk.ResponseType.YES:
            return

        self._set_status(f"Removing {ver}...")
        ver_base = ver.replace("-gentoo-dist", "")
        self._run_cmd(f"emerge --deselect =sys-kernel/gentoo-kernel-bin-{ver_base} 2>/dev/null; true")
        for f in [f"/boot/kernel-{ver}", f"/boot/initramfs-{ver}.img",
                  f"/boot/vmlinuz-{ver}", f"/boot/initrd.img-{ver}"]:
            if os.path.exists(f):
                os.remove(f)
        mod_dir = f"/lib/modules/{ver}"
        if os.path.isdir(mod_dir):
            self._run_cmd(f"rm -rf {mod_dir}")
        self._run_cmd("grub-mkconfig -o /boot/grub/grub.cfg")
        self._refresh_all()
        self._set_status(f"Kernel {ver} removed.")

    def _on_sync(self, widget):
        self.progress.show()
        self._set_status("Syncing portage tree...")

        def do_sync():
            self._run_cmd("emerge --sync")
            GLib.idle_add(self._sync_done)

        threading.Thread(target=do_sync, daemon=True).start()
        GLib.timeout_add(200, self._pulse_progress)

    def _sync_done(self):
        self.progress.hide()
        self._refresh_all()
        self._set_status("Portage synced.")

    def _on_check_kernelorg(self, widget):
        self._set_status("Fetching kernel.org...")
        buf = self.kernelorg_text.get_buffer()
        buf.set_text("Fetching from https://www.kernel.org ...\n")

        def do_fetch():
            try:
                req = urllib.request.Request(
                    "https://www.kernel.org/",
                    headers={"User-Agent": "GentooVM-KernelManager/1.0"}
                )
                with urllib.request.urlopen(req, timeout=15) as resp:
                    html = resp.read().decode("utf-8", errors="replace")

                lines = []
                lines.append("kernel.org — Latest Linux Kernel Releases")
                lines.append("=" * 45)
                lines.append("")

                # Parse releases
                import re as _re
                rows = _re.findall(
                    r'<td[^>]*>(mainline|stable|longterm|linux-next)</td>.*?'
                    r'<strong>([^<]+)</strong>',
                    html, _re.DOTALL
                )
                if rows:
                    lines.append(f"  {'Type':<14} {'Version':<20}")
                    lines.append(f"  {'-'*14} {'-'*20}")
                    for kind, ver in rows:
                        marker = ""
                        if kind == "mainline":
                            marker = "  ★ DEFAULT"
                        elif kind == "stable":
                            marker = "  ★ RECOMMENDED"
                        lines.append(f"  {kind:<14} {ver:<20}{marker}")
                else:
                    lines.append("  Could not parse release table.")
                    lines.append("  Visit https://www.kernel.org manually.")

                lines.append("")
                lines.append("Default: 7.0 (mainline) when available in Gentoo")
                lines.append("Recommended: Latest stable (6.19.x)")
                lines.append("")
                lines.append("Use the 'Available' tab to see what Gentoo has packaged.")
                lines.append("Use 'Sync Portage' to refresh the available list.")

                text = "\n".join(lines)
            except Exception as e:
                text = f"Error fetching kernel.org:\n{e}\n\nVisit https://www.kernel.org manually."

            GLib.idle_add(self._kernelorg_done, text)

        threading.Thread(target=do_fetch, daemon=True).start()

    def _kernelorg_done(self, text):
        buf = self.kernelorg_text.get_buffer()
        buf.set_text(text)
        self._set_status("kernel.org data loaded.")

    def _msg(self, text, error=False):
        dialog = Gtk.MessageDialog(
            parent=self, modal=True,
            message_type=Gtk.MessageType.ERROR if error else Gtk.MessageType.INFO,
            buttons=Gtk.ButtonsType.OK,
            text=text,
        )
        dialog.run()
        dialog.destroy()


def main():
    win = KernelManagerWindow()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    if hasattr(win, 'progress'):
        win.progress.hide()
    Gtk.main()


if __name__ == "__main__":
    main()
